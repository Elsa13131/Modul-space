# Local development example
# Copy this file to .env and fill with your real values

# If DATABASE_URL is set, the app uses PostgreSQL
# If empty, the app falls back to local MySQL
DATABASE_URL=

# Optional local MySQL overrides (used only when DATABASE_URL is empty)
MYSQL_ROOT_DSN=root:@tcp(localhost:3306)/?parseTime=true
MYSQL_DSN=root:@tcp(localhost:3306)/modulspace?parseTime=true

# App
PORT=8080

# Hidden admin access (/admin)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# SMTP (optional for quote email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
